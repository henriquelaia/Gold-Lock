# GoldLock — Variáveis de Ambiente
# Copiar para .env e preencher com os valores reais
# Gerar JWT_SECRET com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ── Segurança ──
JWT_SECRET=muda_isto_para_uma_string_aleatoria_longa_64chars

# ── Base de Dados (automático via Docker — não alterar em dev) ──
DATABASE_URL=postgresql://goldlock:goldlock_dev@postgres:5432/goldlock_db
POSTGRES_DB=goldlock_db
POSTGRES_USER=goldlock
POSTGRES_PASSWORD=goldlock_dev

# ── Redis (automático via Docker) ──
REDIS_URL=redis://redis:6379

# ── Frontend ──
VITE_API_URL=http://localhost:4000/api
FRONTEND_URL=http://localhost:3000

# ── Salt Edge (Open Banking / PSD2) ──
# Registo gratuito em: https://www.saltedge.com/pages/partner_sign_up
# Suporta bancos PT: CGD, Millennium BCP, Santander, BPI, Novobanco, etc.
SALT_EDGE_APP_ID=
SALT_EDGE_SECRET=
SALT_EDGE_BASE_URL=https://www.saltedge.com/api/v5

# ── SMTP (Nodemailer — para emails de verificação e reset) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@goldlock.app

# ── Market Data ──
# Yahoo Finance (ações/ETFs/PSI): não requer API key — usar yahoo-finance2
# CoinGecko (crypto): não requer API key no free tier
# Alpha Vantage (backup opcional): https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# ── Assistente Fiscal IA (Módulo E — opcional) ──
# Sem esta key, o assistente funciona em modo regras (sem IA generativa)
# Obter em: https://platform.openai.com/api-keys
OPENAI_API_KEY=
