# FinTwin — Environment Variables
# Copiar para .env e preencher com os valores reais

# ── Segurança ──
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=muda_isto_para_uma_string_aleatoria_longa

# ── Salt Edge (Open Banking) — obtido em https://www.saltedge.com ──
SALT_EDGE_APP_ID=
SALT_EDGE_SECRET=

# ── OpenAI (opcional, para sugestões conversacionais) ──
OPENAI_API_KEY=

# ── PostgreSQL (automático via Docker — não alterar em dev) ──
DATABASE_URL=postgresql://fintwin:fintwin_dev@postgres:5432/fintwin_db
POSTGRES_DB=fintwin_db
POSTGRES_USER=fintwin
POSTGRES_PASSWORD=fintwin_dev

# ── Redis (automático via Docker) ──
REDIS_URL=redis://redis:6379

# ── Frontend ──
VITE_API_URL=http://localhost:4000/api
